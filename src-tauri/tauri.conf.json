{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BilBiliChat",
  "version": "0.1.0",
  "identifier": "com.ming.bilbilichat",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "BilBiliChat",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "decorations": true,
        "shadow": true,
        "titleBarStyle": "Visible",
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "category": "Utility",
    "copyright": "BilBiliChat",
    "targets": ["dmg", "app", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "digestAlgorithm": "sha256"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["bilbilichat"]
      }
    },
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY0MTVCOThGNEExRDAzOTcKUldTWEF4MUtqN2tWOUtJNDNaTm9zcGV1SDY5YzJPMVVvMExlY0R3MEFYY2F0OHZnVUVmMDcyZEgK",
      "endpoints": [
        "https://github.com/JeffreyMing2004/BilBiliChat/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
